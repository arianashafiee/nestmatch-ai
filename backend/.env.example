# NestMatch AI — Environment Variables
# Copy to .env and fill in optional keys

DATABASE_URL=sqlite:///./nestmatch.db

# ── OPTIONAL API KEYS ──────────────────────────────────────────────
# Apartment SEARCH works without any keys (scrapes public listing pages).
# Keys below improve AI scoring and maps only.

# OpenAI — smarter listing analysis (otherwise uses built-in mock parser)
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Mapbox — live maps on listing detail pages
# 1. Create account: https://account.mapbox.com/
# 2. Create a PUBLIC token (starts with pk.): https://account.mapbox.com/access-tokens/
# 3. Paste token below and restart the backend
MAPBOX_ACCESS_TOKEN=

# Optional custom map style (default is Mapbox Streets)
# MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
