# NestMatch AI — Environment Variables
#
# FIRST-TIME SETUP ONLY (do not re-run if you already have keys in .env):
#   cp .env.example .env
# Then edit .env and paste your keys below. Save the file (Cmd+S).
# Re-running `cp .env.example .env` will ERASE your keys.

DATABASE_URL=sqlite:///./nestmatch.db

# ── OPTIONAL API KEYS ──────────────────────────────────────────────
# Apartment SEARCH works without any keys (scrapes public listing pages).
# Keys below improve AI scoring and maps only.

# OpenAI — GPT web search + smarter listing ranking (requires uncommented line below)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Mapbox — live maps on listing detail pages
# 1. Create account: https://account.mapbox.com/
# 2. Create a PUBLIC token (starts with pk.): https://account.mapbox.com/access-tokens/
# 3. Paste token below and restart the backend
MAPBOX_ACCESS_TOKEN=

# Optional custom map style (default is Mapbox Streets)
# MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12

# Production only — set in Render dashboard (never commit real values)
# Free Render has no persistent disk; use a Neon Postgres connection string:
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
# JWT_SECRET=generate-a-long-random-string
# DEBUG=false
